{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "relaynews-admin",
  "compatibility_date": "2026-04-15",
  "workers_dev": false,
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  },
  "routes": [
    {
      "pattern": "admin.relaynews.ai",
      "custom_domain": true
    }
  ]
}
