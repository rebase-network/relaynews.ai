{
  "name": "relaynews-ai",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r run build",
    "build:admin:prod": "VITE_API_BASE_URL=https://api.relaynew.ai VITE_PUBLIC_SITE_URL=https://relaynew.ai VITE_ADMIN_SITE_URL=https://admin.relaynew.ai pnpm --filter @relaynews/admin run build",
    "build:edge": "bash ops/manage-edge.sh build all",
    "build:web:prod": "VITE_API_BASE_URL=https://api.relaynew.ai VITE_PUBLIC_SITE_URL=https://relaynew.ai pnpm --filter @relaynews/web run build",
    "dev:admin": "pnpm --filter @relaynews/admin run dev",
    "dev:api": "pnpm --filter @relaynews/api run dev",
    "dev:api-edge": "pnpm --filter @relaynews/api-edge run dev",
    "dev:web": "pnpm --filter @relaynews/web run dev",
    "deploy:admin": "bash ops/manage-edge.sh deploy admin",
    "deploy:api": "bash ops/manage.sh deploy",
    "deploy:api-edge": "bash ops/manage-edge.sh deploy api",
    "deploy:edge": "bash ops/manage-edge.sh deploy all",
    "deploy:web": "bash ops/manage-edge.sh deploy web",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:e2e": "playwright test",
    "test:e2e:deployed": "env E2E_DEPLOYED=1 WEB_BASE_URL=https://relaynew.ai ADMIN_BASE_URL=https://admin.relaynew.ai playwright test",
    "test:e2e:deployed:headed": "env E2E_DEPLOYED=1 WEB_BASE_URL=https://relaynew.ai ADMIN_BASE_URL=https://admin.relaynew.ai playwright test --headed",
    "test:e2e:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "dotenv": "17.2.3",
    "wrangler": "^4.82.2"
  }
}
