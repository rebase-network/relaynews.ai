{
  "name": "relaynews-ai",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r run build",
    "build:edge": "bash ops/manage-edge.sh build all",
    "cf:build:admin": "pnpm install --frozen-lockfile && pnpm --filter @relaynews/admin run build",
    "cf:build:web": "pnpm install --frozen-lockfile && pnpm --filter @relaynews/web run build",
    "cf:deploy:admin": "pnpm exec wrangler deploy --config apps/admin/wrangler.jsonc",
    "cf:deploy:web": "pnpm exec wrangler deploy --config apps/web/wrangler.jsonc",
    "cf:preview:admin": "pnpm exec wrangler versions upload --config apps/admin/wrangler.jsonc",
    "cf:preview:web": "pnpm exec wrangler versions upload --config apps/web/wrangler.jsonc",
    "dev:admin": "pnpm --filter @relaynews/admin run dev",
    "dev:api": "pnpm --filter @relaynews/api run dev",
    "dev:api-edge": "pnpm --filter @relaynews/api-edge run dev",
    "dev:web": "pnpm --filter @relaynews/web run dev",
    "deploy:admin": "bash ops/manage-edge.sh deploy admin",
    "deploy:api": "bash ops/manage.sh deploy",
    "deploy:api-edge": "bash ops/manage-edge.sh deploy api",
    "deploy:edge": "bash ops/manage-edge.sh deploy all",
    "deploy:web": "bash ops/manage-edge.sh deploy web",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r run test",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "dotenv": "17.2.3",
    "wrangler": "^4.82.2"
  }
}
