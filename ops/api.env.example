# Production environment for the remote API service
NODE_ENV=production
LOG_LEVEL=info
HOST=0.0.0.0
PORT=8787
POSTGRES_DB=relaynews
POSTGRES_USER=relaynews
POSTGRES_PASSWORD=change-me
DATABASE_URL=postgres://relaynews:change-me@postgres:5432/relaynews
ENABLE_SCHEDULER=true
MONITORING_MAX_MODELS_PER_RELAY=10
MONITORING_FAILURE_BACKOFF_THRESHOLD=3
MONITORING_FAILURE_BACKOFF_MINUTES=120
PUBLIC_PROBE_ALLOW_PRIVATE_HOSTS=false
ADMIN_AUTH_USERNAME=
ADMIN_AUTH_PASSWORD=
CLOUDFLARE_TUNNEL_TOKEN=
